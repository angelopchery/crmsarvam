# Application
APP_NAME=CRMSarvam
APP_VERSION=1.0.0
DEBUG=True

# Database (PostgreSQL with asyncpg)
# For Docker: DATABASE_URL is set in docker-compose.yml
# For local development: use postgresql+asyncpg://postgres:postgres@localhost:5432/crmsarvam
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crmsarvam

# Security
# Generate a strong secret key for production!
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Sarvam AI API Key
# Get your API key from: https://sarvam.ai/
SARVAMAI_API_KEY=your_sarvam_ai_api_key_here

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes

# Media Processing
# FFMPEG_PATH should be in your PATH, or provide full path
FFMPEG_PATH=ffmpeg

# CORS Origins (comma-separated)
# Add your frontend URLs here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
